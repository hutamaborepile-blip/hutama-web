---
/**
 * Tentang Kami page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';

const waNumber = '6281328048030';
const waLink = `https://wa.me/${waNumber}`;
---
<PageLayout
  title="Tentang Hutama Bore Pile — Jasa Bore Pile Profesional di Pulau Jawa"
  description="Hutama Bore Pile adalah perusahaan jasa bore pile profesional yang melayani pondasi bangunan untuk berbagai proyek konstruksi di seluruh Pulau Jawa."
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="building" size="sm" />
      Tentang Kami
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Tentang</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">Hutama Bore Pile</span>
    </h1>
    <p slot="description">
      Jasa Bore Pile Profesional untuk Berbagai Kebutuhan Pondasi di Pulau Jawa.
    </p>
  </Hero>

  <!-- Profil Perusahaan -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 glitch:grid-cols-2 glitch:gap-12">
        <div class="flex flex-col justify-center gap-4 sm:items-center sm:text-center glitch:items-start glitch:text-left" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 sm:items-center glitch:items-start">
            <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">Profil Perusahaan</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
              Kontraktor Bore Pile Terpercaya di Pulau Jawa
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            Hutama Bore Pile merupakan perusahaan jasa bore pile yang melayani pengerjaan pondasi untuk berbagai jenis proyek konstruksi di seluruh kota dan kabupaten di Pulau Jawa. Kami hadir untuk membantu kebutuhan pondasi bangunan dengan sistem kerja profesional, tenaga berpengalaman, dan pengerjaan yang mengutamakan kualitas serta ketepatan waktu.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            Didirikan dan dikelola langsung oleh Pak Hambali, Hutama Bore Pile berkomitmen memberikan layanan terbaik dalam bidang pondasi bore pile untuk rumah, ruko, gudang, gedung, pabrik, sekolah, tempat ibadah, hingga proyek konstruksi skala besar lainnya.
          </p>
        </div>
        <div class="flex flex-col h-full" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="flex-1 flex flex-col justify-center">
            <div class="grid grid-cols-2 sm:grid-cols-3 glitch:grid-cols-2 gap-x-6 gap-y-8">
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="map-pin" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Berbasis di Surabaya</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">Melayani seluruh Pulau Jawa.</p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="user" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Dipimpin Pak Hambali</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">Founder & pengelola langsung.</p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="award" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Tenaga Berpengalaman</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">Tim ahli di bidang pondasi.</p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="layers" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Berbagai Jenis Proyek</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">Rumah hingga gedung bertingkat.</p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="tag" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Harga Kompetitif</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">Transparan dan sesuai kebutuhan.</p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="check-circle" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Tepat Waktu</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">Pengerjaan sesuai jadwal.</p>
                </div>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Fokus Layanan -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <Badge variant="brand" pill>Fokus Layanan</Badge>
        <h2 class="font-display text-4xl font-bold text-foreground">Fokus Pada Kualitas Pondasi Bangunan</h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Pondasi merupakan bagian terpenting dalam sebuah konstruksi. Kami memahami bahwa proses pengerjaan bore pile membutuhkan pengalaman lapangan, perhitungan teknis, dan ketelitian dalam pelaksanaan.
        </p>
      </div>
      <div class="grid gap-6 sm:gap-8 sm:grid-cols-3">
        <Card hover data-reveal>
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="drill" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Bore Pile & Mini Bore Pile</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Pengerjaan bore pile dan mini bore pile untuk berbagai kebutuhan pondasi bangunan.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="home" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Pondasi Rumah & Gedung</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Melayani pondasi rumah tinggal, ruko, gudang, gedung, pabrik, dan proyek lainnya.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="map-pin" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Survey & Konsultasi</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Tim kami siap survey lokasi dan konsultasi kebutuhan pondasi sebelum pengerjaan dimulai.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Keunggulan -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Keunggulan</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Kenapa Memilih Hutama Bore Pile?
        </h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <Card variant="elevated" padding="lg" data-reveal>
          <ul class="flex flex-col gap-4">
            {[
              { icon: 'users', title: 'Tenaga Berpengalaman', desc: 'Pengerjaan dilakukan oleh tim yang telah berpengalaman dalam berbagai proyek pondasi bore pile.' },
              { icon: 'tag', title: 'Harga Kompetitif', desc: 'Kami memberikan penawaran harga yang transparan dan menyesuaikan kebutuhan proyek.' },
              { icon: 'map-pin', title: 'Survey & Konsultasi', desc: 'Kami siap membantu survey lokasi dan konsultasi kebutuhan pondasi sebelum pengerjaan dimulai.' },
              { icon: 'clock', title: 'Pengerjaan Tepat Waktu', desc: 'Setiap proyek dikerjakan dengan perencanaan yang matang agar proses berjalan efisien.' },
            ].map((item) => (
              <li class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0 mt-0.5">
                  <Icon name={item.icon} size="sm" />
                </div>
                <div>
                  <p class="text-sm font-semibold text-foreground">{item.title}</p>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </Card>
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
          <ul class="flex flex-col gap-4">
            {[
              { icon: 'layers', title: 'Support Berbagai Jenis Proyek', desc: 'Kami melayani kebutuhan pondasi untuk proyek rumah pribadi hingga proyek konstruksi skala besar.' },
              { icon: 'globe', title: 'Area Seluruh Pulau Jawa', desc: 'Dengan cakupan area kerja yang luas, kami siap menangani proyek di seluruh Pulau Jawa.' },
              { icon: 'shield', title: 'Kualitas Terjamin', desc: 'Setiap pengerjaan dilakukan dengan standar kualitas tinggi dan pengawasan ketat.' },
              { icon: 'message-circle', title: 'Respon Cepat', desc: 'Tim kami siap merespons pertanyaan dan kebutuhan Anda dengan cepat dan profesional.' },
            ].map((item) => (
              <li class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0 mt-0.5">
                  <Icon name={item.icon} size="sm" />
                </div>
                <div>
                  <p class="text-sm font-semibold text-foreground">{item.title}</p>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-0.5">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </Card>
      </div>
    </div>
  </section>

  <!-- Area Layanan -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Wilayah Kerja</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Melayani Seluruh Wilayah Pulau Jawa
        </h2>
      </div>
      <div class="flex flex-wrap gap-2 justify-center" data-reveal>
        {[
          'Surabaya','Sidoarjo','Gresik','Malang','Mojokerto','Pasuruan',
          'Jakarta','Bekasi','Bogor','Depok','Tangerang','Bandung',
          'Semarang','Yogyakarta','Solo','Madiun','Kediri','Blitar',
          'Jember','Banyuwangi','Probolinggo','Lumajang',
        ].map((kota) => (
          <Badge variant="brand" pill>{kota}</Badge>
        ))}
        <Badge variant="brand" pill>dan seluruh Pulau Jawa</Badge>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Hubungi Kami</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Konsultasikan Kebutuhan Bore Pile Anda Sekarang
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Tim Hutama Bore Pile siap membantu survey lokasi, konsultasi, dan penawaran terbaik untuk proyek Anda.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href={waLink} target="_blank" rel="noopener noreferrer" class="cta-btn-brand">
          <Icon name="message-circle" size="sm" />
          WhatsApp: 0813-2804-803
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Kirim Pesan
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Konsultasikan Kebutuhan Bore Pile Anda Sekarang
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Tim Hutama Bore Pile siap membantu survey lokasi, konsultasi, dan penawaran terbaik untuk proyek Anda.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href={waLink} target="_blank" rel="noopener noreferrer" class="hero-btn-brand">
          <Icon name="message-circle" size="sm" />
          WhatsApp: 0813-2804-803
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Kirim Pesan
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>

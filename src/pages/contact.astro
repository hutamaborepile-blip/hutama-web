---
/**
 * Kontak page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import ContactForm from '@/components/patterns/ContactForm.astro';

const waNumber = '628132804803';
const waLink = `https://wa.me/${waNumber}`;

const channels = [
  {
    icon: 'message-circle',
    label: 'WhatsApp',
    value: '0813-2804-803',
    note: 'Konsultasi cepat via WhatsApp',
    href: waLink,
    external: true,
  },
  {
    icon: 'mail',
    label: 'Email',
    value: 'hutamaborepile@gmail.com',
    note: 'Kirim detail proyek via email',
    href: 'mailto:hutamaborepile@gmail.com',
    external: false,
  },
];
---

<PageLayout
  title="Kontak Hutama Bore Pile"
  description="Hubungi Hutama Bore Pile untuk konsultasi, survey lokasi, dan penawaran jasa bore pile profesional di seluruh Pulau Jawa."
  eagerReveal
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="message-circle" size="sm" />
      Hubungi Kami
    </Badge>
    <h1 slot="title">
      Konsultasikan Kebutuhan <span class="text-brand-500">Bore Pile Anda</span>
    </h1>
    <p slot="description">
      Hutama Bore Pile siap membantu kebutuhan jasa bore pile dan pondasi bangunan untuk berbagai jenis proyek di seluruh kota dan kabupaten di Pulau Jawa.
    </p>
  </Hero>

  <!-- Kontak Section -->
  <section class="relative isolate overflow-hidden py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="relative z-10 mx-auto max-w-5xl px-6">
      <div class="grid grid-cols-1 glitch:grid-cols-5 gap-10 glitch:gap-16 items-stretch">

        <!-- Left column: contact form -->
        <div class="glitch:col-span-3 h-full sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0" data-reveal="right" data-reveal-ease="smooth">
          <Card padding="lg" class="h-full flex flex-col justify-center">
            <h2 class="font-display text-xl font-bold text-foreground mb-6 sm:text-center glitch:text-left">Detail Proyek Anda</h2>
            <ContactForm />
          </Card>
        </div>

        <!-- Right column: contact channels -->
        <div class="glitch:col-span-2 space-y-4 sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <div class="sm:text-center glitch:text-left">
            <h2 class="font-display text-lg font-bold text-foreground mb-1">Kontak Langsung</h2>
            <p class="text-sm text-foreground-muted">Pilih cara yang paling mudah untuk Anda.</p>
          </div>

          <div class="space-y-2">
            {channels.map((ch) => (
              <a
                href={ch.href}
                {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                class="block group"
              >
                <Card hover padding="sm" class="h-full">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                      <Icon name={ch.icon} size="sm" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-sm text-foreground">{ch.label}</p>
                      <p class="text-xs text-foreground-muted truncate">{ch.value}</p>
                    </div>
                    <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                  </div>
                </Card>
              </a>
            ))}
          </div>

          <!-- Alamat -->
          <Card padding="sm" class="bg-brand-500/5 border-brand-500/20">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name="map-pin" size="sm" />
              </div>
              <div>
                <p class="font-semibold text-sm text-foreground">Alamat Kantor</p>
                <p class="text-xs text-foreground-muted mt-0.5">Warugunung, Kec. Karangpilang,<br />Surabaya, Jawa Timur 60221</p>
              </div>
            </div>
          </Card>

          <!-- Jam Operasional -->
          <Card padding="sm">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name="clock" size="sm" />
              </div>
              <div>
                <p class="font-semibold text-sm text-foreground">Jam Operasional</p>
                <p class="text-xs text-foreground-muted mt-0.5">Senin – Sabtu: 08.00 – 17.00 WIB</p>
                <p class="text-xs text-foreground-muted">Minggu: By Appointment</p>
              </div>
            </div>
          </Card>

          <!-- Area Layanan -->
          <Card padding="sm">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name="globe" size="sm" />
              </div>
              <div>
                <p class="font-semibold text-sm text-foreground">Area Layanan</p>
                <p class="text-xs text-foreground-muted mt-0.5">Seluruh kota & kabupaten di Pulau Jawa</p>
              </div>
            </div>
          </Card>
        </div>

      </div>
    </div>
  </section>

  <!-- Kenapa Hubungi Kami -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Kenapa Kami?</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Kenapa Menghubungi Hutama Bore Pile?
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { icon: 'zap', text: 'Respon cepat' },
          { icon: 'message-circle', text: 'Konsultasi gratis' },
          { icon: 'map-pin', text: 'Survey lokasi' },
          { icon: 'users', text: 'Tenaga berpengalaman' },
          { icon: 'tag', text: 'Harga kompetitif' },
          { icon: 'globe', text: 'Melayani seluruh Pulau Jawa' },
        ].map((item) => (
          <Card hover data-reveal class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name={item.icon} size="sm" />
            </div>
            <p class="text-sm font-medium text-foreground">{item.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

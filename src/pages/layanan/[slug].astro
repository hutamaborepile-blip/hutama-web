---
/**
 * Product detail page — fetches live from WooCommerce
 * URL: /layanan/[slug]
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { getProduct, getProducts, formatPrice, stripHtml } from '@/lib/wordpress';
import siteConfig from '@/config/site.config';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/layanan');

const product = await getProduct(slug);

if (!product) return Astro.redirect('/layanan');

const waNumber = '6281328048030';
const waMsg = encodeURIComponent(`Halo, saya ingin konsultasi mengenai layanan: ${product.name}`);
const waLink = `https://wa.me/${waNumber}?text=${waMsg}`;

const canonicalUrl = `${siteConfig.url}/layanan/${product.slug}`;
const seoTitle = product.yoast_head_json?.title || `${product.name} | Hutama Bore Pile`;
const seoDesc = product.yoast_head_json?.description || stripHtml(product.short_description || product.description).slice(0, 160);
const ogImage = product.yoast_head_json?.og_image?.[0]?.url || product.images?.[0]?.src || `${siteConfig.url}/og-default.svg`;

const hasPrice = product.price && parseFloat(product.price) > 0;

// Related products (same category)
const relatedProducts = product.related_ids?.length
  ? await getProducts({ include: product.related_ids.slice(0, 4).join(',') })
  : [];

// Schema markup — Product + Service + BreadcrumbList
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: product.name,
  description: stripHtml(product.description || product.short_description),
  url: canonicalUrl,
  image: product.images?.[0]?.src,
  provider: {
    '@type': 'ConstructionCompany',
    name: siteConfig.name,
    url: siteConfig.url,
    telephone: siteConfig.phone,
    email: siteConfig.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: siteConfig.address?.street,
      addressLocality: siteConfig.address?.city,
      addressRegion: siteConfig.address?.state,
      postalCode: siteConfig.address?.zip,
      addressCountry: 'ID',
    },
  },
  ...(hasPrice ? {
    offers: {
      '@type': 'Offer',
      price: product.price,
      priceCurrency: 'IDR',
      availability: product.stock_status === 'instock'
        ? 'https://schema.org/InStock'
        : 'https://schema.org/OutOfStock',
      url: canonicalUrl,
    },
  } : {}),
  ...(product.average_rating && parseFloat(product.average_rating) > 0 ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: product.average_rating,
      reviewCount: product.rating_count,
    },
  } : {}),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Beranda', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Layanan', item: `${siteConfig.url}/layanan` },
    { '@type': 'ListItem', position: 3, name: product.name, item: canonicalUrl },
  ],
};
---

<PageLayout title={seoTitle} description={seoDesc}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="product" />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav class="bg-background border-b border-border" aria-label="Breadcrumb">
    <div class="mx-auto max-w-6xl px-6 py-3">
      <ol class="flex items-center gap-2 text-sm text-foreground-muted flex-wrap">
        <li><a href="/" class="hover:text-brand-500 transition-colors">Beranda</a></li>
        <li><Icon name="chevron-right" size="sm" class="text-foreground-muted/50" /></li>
        <li><a href="/layanan" class="hover:text-brand-500 transition-colors">Layanan</a></li>
        <li><Icon name="chevron-right" size="sm" class="text-foreground-muted/50" /></li>
        <li class="text-foreground font-medium truncate max-w-[200px]">{product.name}</li>
      </ol>
    </div>
  </nav>

  <!-- Product Detail -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16 items-start">

        <!-- Images -->
        <div class="space-y-4" data-reveal="right">
          {product.images?.length > 0 ? (
            <div class="aspect-video overflow-hidden rounded-2xl bg-background-tertiary border border-border">
              <img
                src={product.images[0].src}
                alt={product.images[0].alt || product.name}
                class="w-full h-full object-cover"
                width="600"
                height="338"
              />
            </div>
          ) : (
            <div class="aspect-video rounded-2xl bg-background-tertiary border border-border flex items-center justify-center">
              <Icon name="drill" class="w-16 h-16 text-foreground-muted/30" />
            </div>
          )}
          {product.images?.length > 1 && (
            <div class="grid grid-cols-4 gap-2">
              {product.images.slice(1, 5).map((img) => (
                <div class="aspect-square overflow-hidden rounded-lg bg-background-tertiary border border-border">
                  <img src={img.src} alt={img.alt || product.name} class="w-full h-full object-cover" loading="lazy" width="120" height="120" />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Info -->
        <div class="flex flex-col gap-5" data-reveal="left" data-reveal-delay="1">
          <!-- Categories -->
          {product.categories?.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {product.categories.map((cat) => (
                <a href={`/layanan?kategori=${cat.slug}`} class="group">
                  <Badge variant="brand" pill class="group-hover:opacity-80 transition-opacity cursor-pointer">{cat.name}</Badge>
                </a>
              ))}
            </div>
          )}

          <h1 class="font-display text-3xl md:text-4xl font-bold text-foreground">{product.name}</h1>

          <!-- Rating -->
          {product.rating_count > 0 && (
            <div class="flex items-center gap-2">
              <div class="flex gap-0.5 text-brand-500">
                {[...Array(5)].map((_, i) => (
                  <svg class={`w-4 h-4 ${i < Math.round(parseFloat(product.average_rating)) ? 'fill-current' : 'fill-foreground-muted/20'}`} viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-sm text-foreground-muted">{product.average_rating} ({product.rating_count} ulasan)</span>
            </div>
          )}

          <!-- Price -->
          {hasPrice && (
            <div class="flex items-baseline gap-3">
              <span class="text-3xl font-bold text-brand-500">{formatPrice(product.price)}</span>
              {product.on_sale && product.regular_price && (
                <span class="text-lg text-foreground-muted line-through">{formatPrice(product.regular_price)}</span>
              )}
            </div>
          )}

          <!-- Short description -->
          {product.short_description && (
            <div class="text-foreground-muted leading-relaxed prose prose-sm max-w-none" set:html={product.short_description} />
          )}

          <!-- Attributes -->
          {product.attributes?.length > 0 && (
            <div class="space-y-2 p-4 rounded-xl bg-background-tertiary border border-border">
              {product.attributes.map((attr) => (
                <div class="flex items-start gap-2 text-sm">
                  <span class="font-semibold text-foreground min-w-[120px] shrink-0">{attr.name}:</span>
                  <span class="text-foreground-muted">{attr.options.join(', ')}</span>
                </div>
              ))}
            </div>
          )}

          <!-- Tags -->
          {product.tags?.length > 0 && (
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-xs font-semibold text-foreground-muted uppercase tracking-wide">Tags:</span>
              {product.tags.map((tag) => (
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-background-tertiary border border-border text-foreground-muted hover:border-brand-500/40 hover:text-brand-500 transition-colors cursor-default">
                  #{tag.name}
                </span>
              ))}
            </div>
          )}

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 flex items-center justify-center gap-2.5 bg-[#25D366] hover:bg-[#20ba5a] active:bg-[#1da851] transition-colors text-white font-semibold text-base px-6 py-3.5 rounded-xl shadow-md shadow-black/10"
            >
              <!-- WhatsApp SVG icon (Wikimedia) -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 175.216 175.552" class="w-5 h-5 shrink-0" aria-hidden="true">
                <path fill="#fff" d="M87.184 25.227c-33.733 0-61.166 27.423-61.178 61.13a60.98 60.98 0 0 0 9.349 32.535l1.455 2.312-6.179 22.559 23.146-6.069 2.235 1.324c9.387 5.571 20.15 8.517 31.126 8.523h.023c33.707 0 61.14-27.426 61.153-61.135a60.75 60.75 0 0 0-17.895-43.251 60.75 60.75 0 0 0-43.235-17.928z"/>
                <path fill="#25D366" d="M87.184 32.227c-29.909 0-54.178 24.261-54.19 54.13a53.98 53.98 0 0 0 8.349 28.535l1.455 2.312-5.179 18.559 19.146-5.069 2.235 1.324c8.387 4.971 17.95 7.617 27.726 7.623h.023c29.907 0 54.14-24.226 54.153-54.135a53.75 53.75 0 0 0-15.895-38.251 53.75 53.75 0 0 0-37.823-15.028z"/>
                <path fill="#fff" fill-rule="evenodd" d="M68.772 55.603c-1.378-3.061-2.828-3.123-4.137-3.176l-3.524-.043c-1.226 0-3.218.46-4.902 2.3s-6.435 6.287-6.435 15.332 6.588 17.785 7.506 19.013 12.718 20.381 31.405 27.75c15.529 6.124 18.689 4.906 22.061 4.6s10.877-4.447 12.408-8.74 1.532-7.971 1.073-8.74-1.685-1.226-3.525-2.146-10.877-5.367-12.562-5.981-2.91-.919-4.137.921-4.746 5.979-5.819 7.206-2.144 1.381-3.984.462-7.76-2.861-14.784-9.124c-5.465-4.873-9.154-10.891-10.228-12.73s-.114-2.835.808-3.751c.825-.824 1.838-2.147 2.759-3.22s1.224-1.84 1.836-3.065.307-2.301-.153-3.22-4.032-10.011-5.67-13.696z"/>
              </svg>
              Pesan Sekarang
            </a>
            <Button size="lg" variant="outline" href="/contact" class="flex-1">
              <Icon name="mail" size="sm" />
              Kirim Inquiry
            </Button>
          </div>

          <!-- Trust signals -->
          <div class="grid grid-cols-2 gap-3 pt-2">
            {[
              { icon: 'check-circle', text: 'Konsultasi Gratis' },
              { icon: 'map-pin', text: 'Survey Lokasi' },
              { icon: 'zap', text: 'Respon Cepat' },
              { icon: 'globe', text: 'Seluruh Pulau Jawa' },
            ].map((item) => (
              <div class="flex items-center gap-2 text-sm text-foreground-muted">
                <Icon name={item.icon} size="sm" class="text-brand-500 shrink-0" />
                {item.text}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Full Description -->
  {product.description && (
    <section class="py-[var(--space-section-md)] bg-background border-t border-border">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-display text-2xl font-bold text-foreground mb-6">Deskripsi Layanan</h2>
        <div class="prose prose-sm max-w-none text-foreground-muted leading-relaxed" set:html={product.description} />
      </div>
    </section>
  )}

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
        <h2 class="font-display text-2xl font-bold text-foreground text-center" data-reveal>
          Layanan Terkait
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {relatedProducts.map((rp, i) => (
            <a href={`/layanan/${rp.slug}`} class="group block" data-reveal data-reveal-delay={String(i)}>
              <Card variant="elevated" hover padding="none" class="flex flex-col h-full">
                {rp.images?.[0] && (
                  <div class="aspect-video overflow-hidden rounded-t-xl bg-background-tertiary">
                    <img src={rp.images[0].src} alt={rp.images[0].alt || rp.name} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" width="300" height="169" />
                  </div>
                )}
                <div class="p-4 flex flex-col flex-1">
                  <h3 class="text-sm font-semibold text-foreground mb-1">{rp.name}</h3>
                  {rp.price && parseFloat(rp.price) > 0 && (
                    <p class="text-sm font-bold text-brand-500 mt-auto">{formatPrice(rp.price)}</p>
                  )}
                </div>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</PageLayout>
